{
  "name": "coverfi-contracts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "CoverFi smart contracts — CoverFiPolicy + MockUSDC on BSC Testnet. Standalone Hardhat subproject; root Next.js app consumes the compiled ABIs via src/lib/contracts/.",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:gas": "hardhat test --gas-stats",
    "test:coverage": "hardhat test --coverage",
    "deploy:testnet": "hardhat ignition deploy ignition/modules/Deploy.ts --network bscTestnet",
    "verify:testnet": "hardhat verify etherscan --build-profile production --network bscTestnet"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox-viem": "^5.0.6",
    "@types/node": "^25.9.1",
    "dotenv": "^17.4.2",
    "hardhat": "^3.5.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.6.1"
  }
}
