# BSC Testnet RPC URL. The public default works as a fallback but
# rate-limits aggressively — for repeated deploys, use a private
# provider (QuickNode / Ankr / your own node).
BSC_TESTNET_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545

# Deployer / settler wallet private key. Use a DEDICATED dev wallet
# that only holds testnet funds, never a wallet with real assets.
# The 0x prefix is auto-added by hardhat.config.ts, so the raw
# 64-hex string from MetaMask (Account Details → Show Private Key)
# works directly — no need to add `0x` yourself.
# This file (.env) is gitignored and MUST NOT be committed.
PRIVATE_KEY=

# BscScan API key, used by `npm run verify:testnet` to publish
# contract source after deployment. Get one free at
# https://bscscan.com/myapikey (one BscScan account covers both
# mainnet and testnet).
BSCSCAN_API_KEY=

# Supabase project URL + publishable key. Used by scripts/settle.ts
# to keep the DB row in sync after a chain-side settlement (the
# frontend handles its own DB writes for buyPolicy / claim — only
# the settler flow needs DB access from this side).
# Same values as the root project's .env.local (the publishable key
# is public-safe; service-role keys, if ever introduced, must stay
# server-only and unprefixed).
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
