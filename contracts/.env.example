# BSC Testnet RPC URL. The public default works as a fallback but
# rate-limits aggressively — for repeated deploys, use a private
# provider (QuickNode / Ankr / your own node).
BSC_TESTNET_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545

# Deployer wallet private key — use a DEDICATED dev wallet that
# only ever holds testnet funds. 0x-prefixed hex string.
# This file (.env) is gitignored; .env.example is the only one
# tracked in git, and it must never contain a real key.
PRIVATE_KEY=

# BscScan API key, used by `npm run verify:testnet` to publish
# contract source after deployment. Get one free at
# https://bscscan.com/myapikey.
BSCSCAN_API_KEY=
